NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://fishing:fishing@localhost:5432/fishing_journal?schema=public
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

